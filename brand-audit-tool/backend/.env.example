# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=brand_audit
DB_USER=postgres
DB_PASSWORD=your_password

# AI Service API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude Model Selection (optional)
# Options: claude-3-haiku-20240307 (default, fastest, cheapest)
#          claude-3-5-sonnet-20240620 (balanced, recommended)
#          claude-3-sonnet-20240229 (balanced)
#          claude-3-opus-20240229 (most capable, expensive)
CLAUDE_MODEL=claude-3-haiku-20240307

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# IBM Brand Resources
IBM_BRAND_GUIDELINES_URL=https://www.ibm.com/brand/
IBM_CARBON_DOCS_URL=https://carbondesignsystem.com/

# Puppeteer Configuration
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# CORS
CORS_ORIGIN=http://localhost:3000